generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
}

enum PolicyStatus {
  ACTIVE
  PENDING
  CANCELLED
  EXPIRED
}

enum ClaimStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  name     String
  role     UserRole @default(EMPLOYEE)
  active   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Company {
  id Int @id @default(autoincrement())

  name String

  nif String? @unique

  email String?

  phone String?

  address String?

  city String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  users User[]

  clients Client[]

  simulations Simulation[]
}

model Client {
  id Int @id @default(autoincrement())

  name String

  nif String? @unique

  birthDate DateTime?

  email String?

  phone String?

  address String?

  postalCode String?

  city String?

  notes String?

  active Boolean @default(true)

  companyId Int

  company Company @relation(fields: [companyId], references: [id])

  policies Policy[]

  claims Claim[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  simulations Simulation[]
}

model Policy {
  id Int @id @default(autoincrement())

  policyNumber String @unique

  product String

  insurer String

  premium Float?

  renewalDate DateTime?

  status PolicyStatus @default(ACTIVE)

  clientId Int

  client Client @relation(fields: [clientId], references: [id])

  claims Claim[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Claim {
  id Int @id @default(autoincrement())

  claimNumber String @unique

  description String?

  status ClaimStatus @default(OPEN)

  clientId Int

  client Client @relation(fields: [clientId], references: [id])

  policyId Int?

  policy Policy? @relation(fields: [policyId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Simulation {
  id Int @id @default(autoincrement())

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  insuranceType String

  premium Float?

  commission Float?

  notes String?

  status String @default("DRAFT")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
