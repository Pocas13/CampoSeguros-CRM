DATABASE_URL="postgresql://USER:PASSWORD@HOST-POOLER/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="alterar-por-uma-chave-longa-e-segura"
JWT_REFRESH_SECRET="alterar-por-outra-chave-longa-e-segura"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3001

# Em produção, mantenha false para não expor a documentação da API.
ENABLE_SWAGGER="false"

# Identificação de veículos
# demo: permite testar com 12-AB-34, AA-00-AA e 34-CD-56
# custom: chama o endpoint configurado em VEHICLE_LOOKUP_API_URL
VEHICLE_LOOKUP_PROVIDER="demo"
VEHICLE_LOOKUP_API_URL=""
VEHICLE_LOOKUP_API_KEY=""

# Chave exclusiva para cifrar credenciais de APIs e webservices das seguradoras.
# Use pelo menos 32 caracteres e não publique no GitHub.
INTEGRATION_ENCRYPTION_KEY="alterar-por-uma-chave-exclusiva-de-32-caracteres"
